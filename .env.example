# leanKohaku .env example
#
# Copy this to `.env` (which is gitignored), then fill in real values.
# The CLI and daemon auto-load `./.env` and `${XDG_CONFIG_HOME:-$HOME/.config}/leankohaku/.env`
# at startup. Real shell env always wins over .env (see LeanKohaku/Util/DotEnv.lean),
# so you can override per-shell with `export …` without editing the file.
#
# Disable .env autoload entirely:  LEANKOHAKU_NO_DOTENV=1

# ---------------------------------------------------------------------------
# RPC URLs
# ---------------------------------------------------------------------------
# Default RPC used by `kohaku balance`, `kohaku send`, etc. when no chain is
# specified. Loopback values are treated as localNode; anything else is
# classified as configuredNode.
#LEANKOHAKU_RPC_URL=http://127.0.0.1:8545

# Per-chain overrides. Either spelling works; LEANKOHAKU_RPC_URL_<NAME> wins
# if both are set. `kohaku network` shows the resolved values + their source.
#MAINNET_RPC_URL=https://your-mainnet-rpc.example/
#SEPOLIA_RPC_URL=https://your-sepolia-rpc.example/
#LEANKOHAKU_RPC_URL_MAINNET=https://your-mainnet-rpc.example/
#LEANKOHAKU_RPC_URL_SEPOLIA=https://your-sepolia-rpc.example/

# Transport classification for the default RPC. Auto-detected for loopback
# URLs; set explicitly for Tor / non-loopback configured nodes.
# Allowed: loopback | direct | tor
#LEANKOHAKU_RPC_TRANSPORT=direct

# Optional: separate ENS resolver RPC. Falls back to LEANKOHAKU_RPC_URL.
#LEANKOHAKU_ENS_RPC_URL=https://your-mainnet-rpc.example/

# ---------------------------------------------------------------------------
# Daemon
# ---------------------------------------------------------------------------
# Network policy: strict | tor | permissive (default: strict)
#LEANKOHAKU_NETWORK_POLICY=strict

# Override the Unix socket path. Default: $XDG_RUNTIME_DIR/leankohaku/leankohaku.sock
#LEANKOHAKU_SOCKET=/tmp/leankohaku.sock

# Chain id the daemon reports/signs against. 1 = mainnet, 11155111 = sepolia.
#LEANKOHAKU_CHAIN_ID=11155111

# Network request log: 1 (default) writes to .leankohaku/logs/, 0 disables.
#LEANKOHAKU_NETWORK_LOG=1

# ---------------------------------------------------------------------------
# Sepolia R1 deploy / dev (used by script/r1_sepolia.sh — NOT required for
# normal `kohaku send` / TUI use)
# ---------------------------------------------------------------------------
# Funded Sepolia EOA private key for deploying the R1 account contract. This
# is only needed for the one-shot deploy step. NEVER commit a real key.
#PRIVATE_KEY=0xreplace_with_a_funded_sepolia_test_key

# Candide bundler API key (Sepolia entrypoint 0.9). Optional.
#CANDIDE_API_KEY=
